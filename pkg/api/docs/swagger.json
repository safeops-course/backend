{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Podinfo-inspired Go microservice for Kubernetes demos. Exposes health probes, chaos endpoints, metrics, and observability features.",
        "title": "SRE Control Plane Backend API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "LDBL Team",
            "url": "https://github.com/ldbl/backend"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/": {
            "get": {
                "description": "Returns HTML landing page with service information",
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "General"
                ],
                "summary": "Landing page",
                "responses": {
                    "200": {
                        "description": "HTML page",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/configs": {
            "get": {
                "description": "Returns values from watched ConfigMaps/Secrets",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Config"
                ],
                "summary": "Config watcher values",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.ConfigsResponse"
                        }
                    }
                }
            }
        },
        "/delay/{seconds}": {
            "get": {
                "description": "Delays the response by the specified number of seconds",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Chaos"
                ],
                "summary": "Delay response",
                "parameters": [
                    {
                        "type": "number",
                        "description": "Delay in seconds",
                        "name": "seconds",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.DelayResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid delay",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/echo": {
            "post": {
                "description": "Returns the request body as-is",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Debug"
                ],
                "summary": "Echo request body",
                "parameters": [
                    {
                        "description": "Request body to echo",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Echoed body",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "204": {
                        "description": "Empty body"
                    },
                    "400": {
                        "description": "Bad request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/env": {
            "get": {
                "description": "Returns all environment variables (use with caution in production)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Debug"
                ],
                "summary": "Environment variables",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/error": {
            "get": {
                "description": "Generates log entries at different levels for testing observability",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Observability"
                ],
                "summary": "Generate test logs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.ErrorResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid level",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Error level generates 500",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/error/{level}": {
            "get": {
                "description": "Generates log entries at different levels for testing observability",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Observability"
                ],
                "summary": "Generate test logs",
                "parameters": [
                    {
                        "type": "string",
                        "default": "error",
                        "description": "Log level: debug, info, warn, error",
                        "name": "level",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.ErrorResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid level",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Error level generates 500",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/headers": {
            "get": {
                "description": "Returns all HTTP request headers",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Debug"
                ],
                "summary": "Request headers",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/healthz": {
            "get": {
                "description": "Returns service health status",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/livez": {
            "get": {
                "description": "Returns liveness status for Kubernetes",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/livez/disable": {
            "put": {
                "description": "Sets the service as not live (triggers container restart)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Disable liveness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/livez/enable": {
            "put": {
                "description": "Sets the service as live",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Enable liveness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "description": "Returns Prometheus metrics in text exposition format",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "Observability"
                ],
                "summary": "Prometheus metrics",
                "responses": {
                    "200": {
                        "description": "Prometheus metrics",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/openapi": {
            "get": {
                "description": "Returns OpenAPI 3.0 specification in JSON format",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Documentation"
                ],
                "summary": "OpenAPI specification",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/panic": {
            "get": {
                "description": "Terminates the process with exit code 255 (for testing pod restarts)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Chaos"
                ],
                "summary": "Terminate process",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/readyz": {
            "get": {
                "description": "Returns readiness status for Kubernetes",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Readiness probe",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/readyz/disable": {
            "put": {
                "description": "Sets the service as not ready (for graceful shutdown testing)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Disable readiness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/readyz/enable": {
            "put": {
                "description": "Sets the service as ready",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Enable readiness",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.StatusResponse"
                        }
                    }
                }
            }
        },
        "/status/{code}": {
            "get": {
                "description": "Returns the specified HTTP status code (for testing)",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "Chaos"
                ],
                "summary": "Return specific HTTP status",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "HTTP status code (100-599)",
                        "name": "code",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status message",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid status code",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/swagger": {
            "get": {
                "description": "Returns Swagger UI HTML page",
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Documentation"
                ],
                "summary": "Swagger UI",
                "responses": {
                    "200": {
                        "description": "HTML page",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/token": {
            "post": {
                "description": "Creates a JWT token valid for 5 minutes",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Generate JWT token",
                "parameters": [
                    {
                        "description": "Username (defaults to 'anonymous')",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.TokenResponse"
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/token/validate": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Validates a JWT token from the Authorization header",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Validate JWT token",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.TokenValidationResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/version": {
            "get": {
                "description": "Returns service version, commit, and build information",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "General"
                ],
                "summary": "Version info",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/pkg_server.VersionResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "pkg_server.ConfigsResponse": {
            "type": "object",
            "properties": {
                "configs": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "enabled": {
                    "type": "boolean",
                    "example": true
                },
                "message": {
                    "type": "string"
                },
                "path": {
                    "type": "string",
                    "example": "/etc/config"
                }
            }
        },
        "pkg_server.DelayResponse": {
            "type": "object",
            "properties": {
                "delay": {
                    "type": "string",
                    "example": "5"
                }
            }
        },
        "pkg_server.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "test error"
                },
                "level": {
                    "type": "string",
                    "example": "error"
                },
                "message": {
                    "type": "string",
                    "example": "error log generated"
                }
            }
        },
        "pkg_server.StatusResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        },
        "pkg_server.TokenResponse": {
            "type": "object",
            "properties": {
                "expires_at": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        },
        "pkg_server.TokenValidationResponse": {
            "type": "object",
            "properties": {
                "expires_at": {
                    "type": "string"
                },
                "issued_at": {
                    "type": "string"
                },
                "token_name": {
                    "type": "string"
                }
            }
        },
        "pkg_server.VersionResponse": {
            "type": "object",
            "properties": {
                "build_time": {
                    "type": "string",
                    "example": "2024-01-01T00:00:00Z"
                },
                "commit": {
                    "type": "string",
                    "example": "abc1234567890"
                },
                "commit_short": {
                    "type": "string",
                    "example": "abc1234"
                },
                "version": {
                    "type": "string",
                    "example": "v1.0.0"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Type \"Bearer\" followed by a space and JWT token",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}